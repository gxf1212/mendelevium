source "https://rubygems.org"

# Use latest Jekyll instead of github-pages for better compatibility
gem "jekyll", "~> 4.3"

# Required gems
gem "kramdown-parser-gfm"
gem "webrick", "~> 1.7"
gem "tzinfo", ">= 1", "< 3"
gem "tzinfo-data"
gem "wdm", "~> 0.1.1", :platforms => [:mingw, :x64_mingw, :mswin]

group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-sitemap"
  gem "jekyll-seo-tag"
  gem "jekyll-paginate"
  gem "jekyll-gist"
end
